{
    "name": "skywalker-labs/laravel-livewire-tables",
    "description": "A dynamic table component for Laravel Livewire",
    "keywords": [
        "skywalker-labs",
        "livewire",
        "datatables",
        "tables",
        "laravel"
    ],
    "homepage": "https://skywalker-labs.com/",
    "license": "MIT",
    "authors": [
        {
            "name": "Skywalker Labs Team",
            "email": "skywalkerlknw@gmail.com",
            "homepage": "https://skywalker-labs.com/",
            "role": "Developer"
        },
        {
            "name": "Mradul Sharma",
            "email": "ermradulsharma0@gmail.com",
            "homepage": "https://mradulsharma.vercel.app/",
            "role": "Lead Developer"
        }
    ],
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/ermradulsharma"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "blade-ui-kit/blade-heroicons": "^2.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "livewire/livewire": "^3.0|^4.0"
    },
    "require-dev": {
        "ext-sqlite3": "*",
        "blade-ui-kit/blade-icons": "^1.8",
        "brianium/paratest": "^5.0|^6.0|^7.0|^8.0",
        "larastan/larastan": "^2.6",
        "laravel/pint": "^1.10",
        "monolog/monolog": "*",
        "nunomaduro/collision": "^6.0|^7.0|^8.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0",
        "phpunit/phpunit": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "SkywalkerLabs\\LaravelLivewireTables\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SkywalkerLabs\\LaravelLivewireTables\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=always",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "SkywalkerLabs\\LaravelLivewireTables\\LaravelLivewireTablesServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
